APP_NAME=MonoReg
APP_ENV=development
SECRET_KEY=change-me-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=postgresql+psycopg2://monoreg:monoreg@postgres:5432/monoreg
REDIS_URL=redis://redis:6379/0

PASSWORD_ENCRYPTION_KEY=change-me-32-byte-key

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=example@example.com
SMTP_PASSWORD=password
SMTP_FROM_NAME=MonoReg
SMTP_FROM_EMAIL=example@example.com
SMTP_USE_SSL=true

BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

INIT_ADMIN_USERNAME=admin
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=admin123456

POSTGRES_USER=monoreg
POSTGRES_PASSWORD=monoreg
POSTGRES_DB=monoreg

